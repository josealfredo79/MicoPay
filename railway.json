{
  "$schema": "https://railway.app/railway.json",
  "build": {
    "builder": "dockerfile",
    "dockerfile": "Dockerfile.railway"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "on_failure",
    "restartPolicyMaxRetries": 10,
    "healthcheck": {
      "path": "/health",
      "interval": 30,
      "timeout": 10
    }
  }
}