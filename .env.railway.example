# Railway Environment Variables
# Copia este archivo a .env y completa los valores

# Puerto
PORT=3000

# PostgreSQL (añade en Railway → Databases → Add PostgreSQL)
DATABASE_URL=postgresql://user:password@ hostname:5432/railway

# JWT
JWT_SECRET=genera_un_jwt_secret_largo_32_caracteres_minimo

# Stellar
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK=TESTNET

# Escrow Contract (testnet)
ESCROW_CONTRACT_ID=CA7F66DXPRSNS4TJGKOZX7BNWBD4FWDKJZ65BEMVMZVHLFY3XCFTTIEV

# Plataforma (genera con: stellar keys generate)
PLATFORM_SECRET_KEY=TuSecretKeyAqui
PLATFORM_STELLAR_ADDRESS=TuPublicKeyAqui

# Encryption
SECRET_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef

# Modo (false para production on-chain)
MOCK_STELLAR=false
NODE_ENV=production