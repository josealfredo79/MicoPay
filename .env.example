# Micopay Protocol — Environment Variables
# Copy to .env and fill in your values

# Stellar
STELLAR_NETWORK=TESTNET
STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# Contracts (deployed on testnet)
ESCROW_CONTRACT_ID=C...       # Required: MicopayEscrow contract address
MXNE_CONTRACT_ID=             # Optional: MXNE token contract
MXNE_ISSUER_ADDRESS=          # Optional: MXNE issuer address

# Platform wallet (REQUIRED in production)
PLATFORM_SECRET_KEY=          # Required: Stellar secret key (S...) - DO NOT COMMIT
PLATFORM_STELLAR_ADDRESS=     # Optional: G... address (derived from secret)

# HTLC encryption (optional)
SECRET_ENCRYPTION_KEY=        # Optional: 32-byte key for encrypting HTLC secrets

# JWT (defaults are insecure, change in production!)
JWT_SECRET=your_secret_here    # Required in production
JWT_EXPIRY=24h

# Agent
ANTHROPIC_API_KEY=           # sk-ant-... (for AI agent features)
AGENT_STELLAR_ADDRESS=       # Agent's Stellar address for x402 payments

# API
PORT=3000
NODE_ENV=development         # development | production | test

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/micopay

# MVP flags
MOCK_STELLAR=false           # Use mock Stellar for testing without network
